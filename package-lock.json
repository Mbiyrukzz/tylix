{
  "name": "tylix-monorepo",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "tylix-monorepo",
      "version": "0.1.0",
      "license": "ISC",
      "workspaces": [
        "packages/*"
      ]
    },
    "node_modules/@tylix/cli": {
      "resolved": "packages/cli",
      "link": true
    },
    "node_modules/@tylix/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@tylix/generator": {
      "resolved": "packages/generator",
      "link": true
    },
    "node_modules/@tylix/orm": {
      "resolved": "packages/orm",
      "link": true
    },
    "node_modules/@tylix/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "node_modules/create-tylix": {
      "resolved": "packages/create-tylix",
      "link": true
    },
    "packages/cli": {
      "name": "@tylix/cli",
      "version": "0.1.0",
      "dependencies": {
        "@tylix/core": "*",
        "@tylix/generator": "*",
        "@tylix/orm": "*",
        "@tylix/shared": "*"
      },
      "bin": {
        "tylix": "src/index.js"
      }
    },
    "packages/core": {
      "name": "@tylix/core",
      "version": "0.1.0",
      "dependencies": {
        "@tylix/orm": "*",
        "@tylix/shared": "*"
      }
    },
    "packages/create-tylix": {
      "version": "0.1.0",
      "bin": {
        "create-tylix": "src/index.js"
      }
    },
    "packages/generator": {
      "name": "@tylix/generator",
      "version": "0.1.0",
      "dependencies": {
        "@tylix/shared": "*"
      }
    },
    "packages/orm": {
      "name": "@tylix/orm",
      "version": "0.1.0",
      "dependencies": {
        "@tylix/shared": "*"
      }
    },
    "packages/shared": {
      "name": "@tylix/shared",
      "version": "0.1.0"
    }
  }
}
